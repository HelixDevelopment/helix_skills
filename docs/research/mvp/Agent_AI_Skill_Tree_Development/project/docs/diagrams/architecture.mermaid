graph TB
    subgraph "Client Layer"
        CLI["CLI (skillctl)
        Cobra framework"]
        TUI["TUI (skill-tui)
        Bubbletea"]
        MCP_CLIENT["MCP Clients
        Claude Code / OpenCode"]
        WEB["Web / curl"]
    end

    subgraph "API Layer"
        GIN["Gin Router
        HTTP handlers"]
        HTTP2["HTTP/2 Server
        Port 8080 (TCP)"]
        HTTP3["HTTP/3 Server
        Port 8443 (UDP)"]
        MCP_SERVER["MCP Server
        JSON-RPC 2.0"]
        MIDDLEWARE["Middleware
        Auth / Logging / Recovery"]
    end

    subgraph "Business Logic"
        REGISTRY["Skill Registry
        CRUD + Graph ops"]
        EXPAND["Auto-Expand Engine
        LLM-powered discovery"]
        VALIDATE["Validation Engine
        Evidence scoring"]
        CODE_ANALYSIS["Code Analysis
        Tree-sitter / AST"]
        EMBED["Embedding Engine
        Vector generation"]
        MEMORY["4-Tier Memory
        Working / Episodic / Semantic / Procedural"]
    end

    subgraph "Data Access"
        DB_LAYER["Database Layer
        pgx connection pool"]
        CACHE["In-Memory Cache
        LRU eviction"]
        QUEUE["Task Queue
        Priority-based"]
    end

    subgraph "Data Storage"
        PG[(PostgreSQL 16
        pgvector extension)]
        EVIDENCE_DIR[("Evidence Files
        /data/evidence")]
    end

    subgraph "External Services"
        LLM["LLM Provider
        OpenAI / Anthropic / Ollama"]
        GIT["Git Repository
        Codebase"]
        PROMETHEUS["Prometheus
        Metrics"]
    end

    CLI --> HTTP2
    TUI --> HTTP2
    WEB --> HTTP2
    WEB --> HTTP3
    MCP_CLIENT --> MCP_SERVER
    
    HTTP2 --> GIN
    HTTP3 --> GIN
    MCP_SERVER --> REGISTRY
    
    GIN --> MIDDLEWARE
    MIDDLEWARE --> REGISTRY
    MIDDLEWARE --> EMBED
    
    REGISTRY --> DB_LAYER
    EXPAND --> DB_LAYER
    EXPAND --> CODE_ANALYSIS
    EXPAND --> LLM
    VALIDATE --> DB_LAYER
    VALIDATE --> CODE_ANALYSIS
    VALIDATE --> GIT
    EMBED --> DB_LAYER
    MEMORY --> CACHE
    MEMORY --> DB_LAYER
    
    CODE_ANALYSIS --> GIT
    
    DB_LAYER --> PG
    CACHE --> PG
    QUEUE --> WORKER
    
    REGISTRY --> EVIDENCE_DIR
    CODE_ANALYSIS --> EVIDENCE_DIR
    
    GIN --> PROMETHEUS
    DB_LAYER --> PROMETHEUS
    
    style CLI fill:#e1f5fe
    style TUI fill:#e1f5fe
    style MCP_CLIENT fill:#e1f5fe
    style WEB fill:#e1f5fe
    style PG fill:#fff3e0
    style LLM fill:#f3e5f5
