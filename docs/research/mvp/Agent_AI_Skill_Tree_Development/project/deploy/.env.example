# =============================================================================
# HelixKnowledge Skill Graph Service - deploy/ environment template (R15)
# =============================================================================
# Copy this file to `.env` in this same directory (deploy/.env) and edit as
# needed. `deploy/.env` is git-ignored (never commit real credentials, per
# the project's secrets-handling policy) - this .env.example is the tracked,
# documented reference.
#
# Every variable below has a dev-safe default baked directly into
# docker-compose.yml (via ${VAR:-default} substitution), so the stack will
# run even with no .env file at all. Create one only when you need to
# override a default - e.g. a non-default port, or real credentials outside
# local development.
# =============================================================================

# -----------------------------------------------------------------------
# Compose project identity
# -----------------------------------------------------------------------
# Used to namespace containers/volumes/networks so multiple checkouts (or
# multiple projects) never collide on a shared host.
COMPOSE_PROJECT_NAME=helix-skills

# -----------------------------------------------------------------------
# PostgreSQL + pgvector datastore
# -----------------------------------------------------------------------
# Database name created on first boot.
DB_NAME=skilldb

# Database role created on first boot and used by the app/ops scripts.
DB_USER=skilluser

# CHANGE THIS for anything beyond local development.
DB_PASSWORD=skillpassword

# Host port PostgreSQL is published on (container always listens on 5432
# internally). Override if 5432 is already taken on the host.
DB_PORT=5432

# -----------------------------------------------------------------------
# Application (reserved - see the commented `app` service in
# docker-compose.yml; not active until the Go binary builds a real image)
# -----------------------------------------------------------------------
# VERSION=dev
# HTTP_PORT=8080
