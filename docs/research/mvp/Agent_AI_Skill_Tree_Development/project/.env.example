# =============================================================================
# HelixKnowledge Skill Graph System - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# All values have sensible defaults for local development.
# =============================================================================

# =============================================================================
# Application
# =============================================================================
VERSION=1.0.0
COMMIT=unknown
BUILD_TIME=unknown
LOG_LEVEL=info                    # debug, info, warn, error

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DB_HOST=db
DB_PORT=5432
DB_NAME=skilldb
DB_USER=skilluser
DB_PASSWORD=skillpassword         # CHANGE IN PRODUCTION
DB_SSL_MODE=disable               # require, verify-full (production)
DB_MEMORY_LIMIT=1G

# Connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# =============================================================================
# API Server
# =============================================================================
HTTP_PORT=8080
HTTP3_PORT=8443
API_MEMORY_LIMIT=512M
API_CPU_LIMIT=1

# Feature flags
ENABLE_HTTP3=true
ENABLE_METRICS=true
ENABLE_AUTO_EXPAND=true
ENABLE_CORS=true

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =============================================================================
# Background Worker
# =============================================================================
WORKER_MEMORY_LIMIT=1G
WORKER_CPU_LIMIT=2
WORKER_CONCURRENCY=4
WORKER_QUEUE_SIZE=100
WORKER_POLL_INTERVAL=30s

# =============================================================================
# Embedding Configuration
# =============================================================================
EMBEDDING_PROVIDER=local          # local, openai, ollama
EMBEDDING_DIMENSION=768           # 768 (local), 1536 (OpenAI), 4096 (Ollama)
EMBEDDING_BATCH_SIZE=32

# OpenAI embedding (optional)
OPENAI_API_KEY=                   # sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama embedding (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# =============================================================================
# Auto-Expansion (LLM-powered skill graph growth)
# =============================================================================
AUTO_EXPAND_ENABLED=true
AUTO_EXPAND_MAX_DEPTH=3
AUTO_EXPAND_CONFIDENCE_THRESHOLD=0.7
AUTO_EXPAND_COOLDOWN=24h

# LLM provider for auto-expansion
LLM_PROVIDER=                     # openai, anthropic, ollama, local
LLM_API_KEY=
LLM_MODEL=                        # gpt-4, claude-3-sonnet, llama3, etc.
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# =============================================================================
# Validation Pipeline
# =============================================================================
VALIDATION_ENABLED=true
VALIDATION_INTERVAL=1h
VALIDATION_BATCH_SIZE=50
VALIDATION_AUTO_FIX=true

# =============================================================================
# Code Analysis
# =============================================================================
CODE_ANALYSIS_ENABLED=true
CODE_ANALYSIS_MAX_FILES=1000
CODE_ANALYSIS_MAX_DEPTH=5
CODE_ANALYSIS_INCLUDE_PATTERNS=*.go,*.rs,*.py,*.js,*.ts,*.java,*.c,*.cpp,*.h
CODE_ANALYSIS_EXCLUDE_PATTERNS=vendor,node_modules,target,build,dist,*.pb.go

# Source code path for analysis (mount into worker container)
SOURCE_CODE_PATH=

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=                       # Generate with: openssl rand -base64 32
API_KEY=                          # Static API key for service-to-service auth

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# HelixKnowledge server auth (read by the Go config loader; internal/config).
# These govern BOTH /api/v1 and /mcp/v1.
# HELIX_API_KEYS: comma-separated API keys accepted via the X-API-Key header.
# Leave EMPTY here — set real keys only in your private, un-committed .env
# (§11.4.10). With no keys and HELIX_AUTH_DISABLED unset, the server is
# FAIL-CLOSED: every /api/v1 and /mcp/v1 request is rejected with HTTP 503.
HELIX_API_KEYS=
# HELIX_AUTH_DISABLED: set to true (or 1) to run the API and MCP HTTP routes
# with NO authentication. Leave empty/false for the fail-closed default.
HELIX_AUTH_DISABLED=
# HELIX_CODEANALYSIS_ALLOWED_ROOT: the single filesystem root that the
# learn_from_project MCP tool's project_path argument MUST canonicalize
# inside (§G31 path-traversal / LFI guard). Leave EMPTY for the fail-closed
# default -- every project_path submission is rejected until this is set.
HELIX_CODEANALYSIS_ALLOWED_ROOT=

# =============================================================================
# MCP (Model Context Protocol) Server
# =============================================================================
MCP_SERVER_NAME=skill-system
MCP_VERSION=1.0.0
MCP_TRANSPORT=stdio               # stdio, sse
MCP_ALLOWED_ORIGINS=*

# =============================================================================
# Monitoring (optional - enable with: docker compose --profile monitoring up)
# =============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin            # CHANGE IN PRODUCTION

# =============================================================================
# Memory Architecture
# =============================================================================
# Working memory (short-term context)
WORKING_MEMORY_SIZE=100
WORKING_MEMORY_TTL=1h

# Episodic memory (event history)
EPISODIC_MEMORY_ENABLED=true
EPISODIC_MEMORY_RETENTION=30d

# Semantic memory (skill embeddings)
SEMANTIC_MEMORY_CACHE_SIZE=10000

# Procedural memory (execution patterns)
PROCEDURAL_MEMORY_ENABLED=true

# =============================================================================
# Storage
# =============================================================================
EVIDENCE_STORAGE_PATH=/data/evidence
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Advanced
# =============================================================================

# HTTP/3 specific
HTTP3_MAX_STREAMS=100
HTTP3_IDLE_TIMEOUT=30s

# Request timeouts
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=30s

# Profiling (development only)
ENABLE_PPROF=false
PPROF_PORT=6060
