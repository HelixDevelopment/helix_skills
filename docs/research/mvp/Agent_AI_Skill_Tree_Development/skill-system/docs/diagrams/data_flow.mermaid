flowchart TD
    subgraph "Skill Lifecycle"
        direction LR
        
        subgraph "Creation"
            A["User Input
            or Auto-Detect"] --> B["Skill Candidate"]
            C["Code Analysis"] --> B
            D["LLM Suggestion"] --> B
        end
        
        subgraph "Validation"
            B --> E{"Confidence
            Score"}
            E -->|"> 0.7"| F["Proposed Skill"]
            E --|"< 0.7"|--> G["Human Review
            Queue"]
            G -->|"Approved"| F
            G -->|"Rejected"| H["Discarded"]
        end
        
        subgraph "Evidence Collection"
            F --> I["Evidence Sources"]
            I --> J["Git Commits"]
            I --> K["Code Files"]
            I --> L["Pull Requests"]
            I --> M["Documentation"]
        end
        
        subgraph "Activation"
            J --> N["Validation Pipeline"]
            K --> N
            L --> N
            M --> N
            N --> O{"Evidence
            Score"}
            O -->|"> 0.8"| P["Validated
            Skill"]
            O -->|"0.5-0.8"| Q["Partial
            Evidence"]
            O -->|"< 0.5"| R["Needs More
            Evidence"]
        end
        
        subgraph "Maintenance"
            P --> S["Continuous
            Monitoring"]
            Q --> S
            R --> T["Evidence
            Request"]
            S --> U{"Skill Still
            Relevant?"}
            U -->|"Yes"| V["Active Skill"]
            U -->|"No"| W["Deprecated
            Skill"]
            V --> X["Auto-Expand
            Trigger"]
            X --> D
        end
    end

    style A fill:#e3f2fd
    style F fill:#fff8e1
    style P fill:#e8f5e9
    style W fill:#ffebee
    style H fill:#fafafa
