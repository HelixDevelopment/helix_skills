graph TB
    subgraph "Programming Languages"
        JAVA["Java"]
        CPP["C++"]
        GO["Go"]
        RUST["Rust"]
        PYTHON["Python"]
    end
    
    subgraph "Systems & Platforms"
        ANDROID["Android AOSP"]
        LINUX["Linux Kernel"]
        K8S["Kubernetes"]
        DOCKER["Docker"]
    end
    
    subgraph "Concepts & Patterns"
        CONCURRENCY["Concurrency"]
        MEMORY["Memory Management"]
        NETWORKING["Networking"]
        SECURITY["Security"]
        DESIGN["System Design"]
    end
    
    subgraph "Frameworks & Tools"
        SPRING["Spring Boot"]
        TOKIO["Tokio"]
        DJANGO["Django"]
        GIN["Gin"]
    end

    %% Android AOSP dependencies
    ANDROID -->|"built on"| JAVA
    ANDROID -->|"uses"| CPP
    ANDROID -->|"uses"| LINUX
    
    %% Language fundamentals
    JAVA -->|"requires"| CONCURRENCY
    CPP -->|"requires"| MEMORY
    GO -->|"requires"| CONCURRENCY
    RUST -->|"requires"| MEMORY
    PYTHON -->|"benefits from"| DESIGN
    
    %% Memory management relationships
    CPP -->|"influenced"| RUST
    MEMORY -->|"related"| SECURITY
    
    %% Framework dependencies
    SPRING -->|"requires"| JAVA
    GIN -->|"requires"| GO
    TOKIO -->|"requires"| RUST
    DJANGO -->|"requires"| PYTHON
    
    %% Platform dependencies
    K8S -->|"uses"| DOCKER
    K8S -->|"requires"| NETWORKING
    DOCKER -->|"uses"| LINUX
    LINUX -->|"requires"| C
    
    %% Cross-cutting concerns
    CONCURRENCY -->|"applies to"| NETWORKING
    NETWORKING -->|"requires"| SECURITY
    DESIGN -->|"encompasses"| CONCURRENCY
    DESIGN -->|"encompasses"| NETWORKING
    
    %% Learning paths
    JAVA -.->|"leads to"| SPRING
    GO -.->|"leads to"| GIN
    GO -.->|"leads to"| K8S
    RUST -.->|"leads to"| TOKIO
    PYTHON -.->|"leads to"| DJANGO
    CPP -.->|"leads to"| ANDROID

    style ANDROID fill:#3DDC84,color:#000
    style JAVA fill:#f89820,color:#000
    style CPP fill:#00599C,color:#fff
    style GO fill:#00ADD8,color:#fff
    style RUST fill:#CE422B,color:#fff
    style PYTHON fill:#3776AB,color:#fff
    style K8S fill:#326CE5,color:#fff
    style DOCKER fill:#2496ED,color:#fff
